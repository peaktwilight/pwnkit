---
import Layout from './Layout.astro';
import DockNav from '../components/DockNav.tsx';

interface Props {
  title: string;
  date: string;
  description: string;
  readTime?: string;
}

const { title, date, description, readTime } = Astro.props;

// Format date for display
const displayDate = new Date(date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} - pwnkit`} description={description}>

  <DockNav client:load />

  <main class="pt-28 pb-24">
    <article class="max-w-2xl mx-auto px-6">

      <!-- Header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 text-sm text-ash mb-4">
          <time datetime={date}>{displayDate}</time>
          {readTime && (
            <>
              <span>&middot;</span>
              <span>{readTime}</span>
            </>
          )}
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight mb-4">
          {title}
        </h1>
        <p class="text-xl text-smoke leading-relaxed">
          {description}
        </p>
      </header>

      <!-- Body -->
      <div class="blog-prose prose prose-invert max-w-none space-y-6 text-smoke leading-relaxed">
        <slot />

        <div class="flex flex-wrap gap-3 mt-8">
          <a href="https://github.com/peaktwilight/pwnkit" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-crimson hover:bg-crimson-light text-white font-medium rounded-lg px-5 py-2.5 transition-colors text-sm no-underline">
            Star on GitHub
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://www.npmjs.com/package/pwnkit" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-medium rounded-lg px-5 py-2.5 transition-colors text-sm no-underline">
            View on npm
          </a>
        </div>
      </div>
    </article>
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/5 py-8">
    <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ash">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-sm bg-crimson inline-block"></span>
        <span>pwnkit</span>
        <span>&middot;</span>
        <span>Apache 2.0</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="https://github.com/peaktwilight/pwnkit" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
        <a href="https://github.com/peaktwilight/pwnkit/issues" target="_blank" rel="noopener" class="hover:text-white transition-colors">Issues</a>
        <a href="https://www.npmjs.com/package/pwnkit" target="_blank" rel="noopener" class="hover:text-white transition-colors">npm</a>
      </div>
    </div>
  </footer>
</Layout>

<style is:global>
  /* Blog prose styles for Markdown content */
  .blog-prose h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-prose h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: white;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .blog-prose p {
    margin-bottom: 1.5rem;
  }

  .blog-prose strong {
    color: white;
  }

  .blog-prose a {
    color: var(--color-crimson, #e53e3e);
    transition: color 0.15s;
  }
  .blog-prose a:hover {
    opacity: 0.8;
  }

  .blog-prose ul, .blog-prose ol {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }
  .blog-prose ul li, .blog-prose ol li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .blog-prose ul li::before {
    content: "\2014";
    color: var(--color-ash, #8b8b8b);
    margin-top: 0.125rem;
    flex-shrink: 0;
  }

  .blog-prose code {
    color: white;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
  }

  .blog-prose pre {
    background: var(--color-night-lighter, #1a1a2e);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    padding: 1rem;
    font-size: 0.875rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .blog-prose pre code {
    background: none;
    padding: 0;
    font-size: inherit;
    color: var(--color-smoke, #c4c4c4);
  }

  .blog-prose blockquote {
    border-left: 2px solid rgba(255, 255, 255, 0.1);
    padding-left: 1rem;
    color: var(--color-ash, #8b8b8b);
    margin: 1.5rem 0;
  }

  .blog-prose em {
    font-style: italic;
  }
</style>
