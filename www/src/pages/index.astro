---
import Layout from '../layouts/Layout.astro';
import PipelineViz from '../components/PipelineViz';
import DockNav from '../components/DockNav';
import DataGridBackground from '../components/DataGridBackground';
import PwnkitHero3D from '../components/PwnkitHero3D';
---

<Layout title="pwnkit - Open-source agentic framework for autonomous security research">


  <main>

    <!-- Hero -->
    <section data-section="hero" class="relative min-h-screen pt-16 sm:pt-24 pb-12 sm:pb-16 overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <!-- 3D pwnkit character -->
        <div class="animate-fade-up">
          <PwnkitHero3D client:only="react" />
        </div>

        <div class="animate-fade-up">
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-8" style="font-family: 'Outfit', sans-serif">
            AI writes the code.<br/><span class="text-crimson">pwnkit hacks it.</span>
          </h1>
        </div>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-4 animate-fade-up" style="animation-delay: 0.2s">
          <div class="copy-wrap relative inline-flex items-center group">
            <code class="bg-night-lighter border border-white/10 rounded-lg px-5 py-3 pr-11 text-sm font-mono text-white select-all cursor-pointer hover:border-crimson/30 transition-colors" data-copy="npx pwnkit-cli">npx pwnkit-cli</code>
            <button class="copy-btn absolute right-2 p-1.5 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli">
              <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
            </button>
          </div>
          <a href="https://github.com/peaktwilight/pwnkit" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white hover:bg-white/90 text-black font-medium rounded-lg px-5 py-3 transition-colors text-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
        <p class="text-xs text-ash mb-16 animate-fade-up" style="animation-delay: 0.3s">
          Or read the <a href="https://github.com/peaktwilight/pwnkit#readme" target="_blank" rel="noopener" class="text-smoke underline underline-offset-2 decoration-white/20 hover:decoration-white/50 hover:text-white transition-colors">documentation</a>
        </p>

        <!-- Demo GIF — real CLI output, not a simulation -->
        <div class="animate-fade-up max-w-5xl mx-auto" style="animation-delay: 0.4s">
          <div class="rounded-xl overflow-hidden border border-white/10">
            <img src="/demo.gif" alt="pwnkit scanning a target and finding vulnerabilities" class="w-full" loading="eager" style="max-width: 100%" />
          </div>
          <!-- Static fallback for no-JS -->
          <noscript>
          <div class="rounded-xl overflow-hidden border border-white/10">
            <div class="bg-night-lighter border-b border-white/5 px-4 py-2.5 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
              </div>
              <span class="text-xs text-ash font-mono ml-2">Terminal</span>
            </div>
            <div class="bg-night-light p-5 font-mono text-sm text-left leading-relaxed space-y-1">
              <div class="text-ash terminal-line">$ npx pwnkit-cli express</div>
              <div class="terminal-line">&nbsp;</div>
              <div class="text-smoke terminal-line">
                <svg class="w-5 h-5 inline-block" viewBox="0 0 32 32"><rect width="32" height="32" rx="6" fill="#0a0a0a"/><path d="M8 12 L16 6 L24 12 L24 22 L20 26 L16 22 L12 26 L8 22Z" fill="none" stroke="#DC2626" stroke-width="2" stroke-linejoin="round"/><circle cx="13" cy="16" r="1.5" fill="#DC2626"/><circle cx="19" cy="16" r="1.5" fill="#DC2626"/></svg> pwnkit-cli v0.1.0
              </div>
              <div class="text-smoke terminal-line">
                <span class="inline-block w-2 h-2 rounded-sm bg-crimson"></span> Target: https://demo.app/api/chat
              </div>
              <div class="terminal-line">&nbsp;</div>
              <div class="text-emerald-400 terminal-line">
                &#9656; Discover &nbsp;Found 3 endpoints, system prompt extracted
              </div>
              <div class="text-amber-400 terminal-line">
                &#9656; Attack &nbsp;&nbsp;&nbsp;Ran 47 test cases across 6 categories
              </div>
              <div class="text-blue-400 terminal-line">
                &#9656; Verify &nbsp;&nbsp;&nbsp;Confirmed 4 of 7 findings (3 false positives eliminated)
              </div>
              <div class="text-purple-400 terminal-line">
                &#9656; Report &nbsp;&nbsp;&nbsp;Written to ./pwnkit-report/
              </div>
              <div class="terminal-line">&nbsp;</div>
              <div class="terminal-line">
                <span class="text-crimson font-bold">4 verified vulnerabilities found.</span>
              </div>
              <div class="terminal-line">
                <table class="w-full text-xs sm:text-sm mt-2 border-collapse">
                  <thead>
                    <tr class="text-ash border-b border-white/10">
                      <th class="text-left py-1 pr-4">ID</th>
                      <th class="text-left py-1 pr-4">Finding</th>
                      <th class="text-left py-1 pr-4">Risk</th>
                      <th class="text-left py-1">Conf</th>
                    </tr>
                  </thead>
                  <tbody class="text-smoke">
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-001</td>
                      <td class="py-1 pr-4">Direct prompt injection</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">99%</td>
                    </tr>
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-002</td>
                      <td class="py-1 pr-4">System prompt extraction</td>
                      <td class="py-1 pr-4 text-amber-400 font-medium">MED</td>
                      <td class="py-1">95%</td>
                    </tr>
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-003</td>
                      <td class="py-1 pr-4">SSRF via tool callback</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">97%</td>
                    </tr>
                    <tr>
                      <td class="py-1 pr-4 text-white">NF-004</td>
                      <td class="py-1 pr-4">PII leak in chat context</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">92%</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          </noscript>
        </div>
      </div>
    </section>

    <!-- What you can scan -->
    <section class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 text-center" style="font-family: 'Outfit', sans-serif">General-purpose autonomous pentesting.</h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center ">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">LLM Endpoints</h3>
            <p class="text-xs text-ash">ChatGPT, Claude, Llama APIs, custom chatbots</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center ">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">npm Packages</h3>
            <p class="text-xs text-ash">Supply chain, malicious code, dependency risk</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center ">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">Source Code</h3>
            <p class="text-xs text-ash">Local repos, GitHub URLs, deep AI audit</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 5 Commands -->
    <section id="commands" data-section="commands" class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 text-center" style="font-family: 'Outfit', sans-serif">Just give it a target.</h2>

        <!-- Compact command grid -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {[
            { cmd: "pwnkit-cli express", desc: "Audit an npm package", color: "text-amber-400" },
            { cmd: "pwnkit-cli ./my-repo", desc: "Review source code", color: "text-blue-400" },
            { cmd: "pwnkit-cli https://api.com/chat", desc: "Scan an LLM endpoint", color: "text-crimson" },
          ].map((item) => (
            <div class="bg-night-lighter border border-white/5 rounded-xl p-4 hover:border-white/10 transition-colors">
              <code class="text-sm font-mono text-white">{item.cmd}</code>
              <p class={`text-xs mt-1 ${item.color}`}>{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why pwnkit -->
    <section class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 text-center" style="font-family: 'Outfit', sans-serif">Why pwnkit</h2>

        <div class="grid sm:grid-cols-3 gap-4">
          <div class="bg-night-lighter border border-white/5 rounded-xl p-6 hover:border-crimson/20 transition-colors">
            <div class="w-8 h-8 mb-4 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-2">Zero config</h3>
            <p class="text-xs text-ash leading-relaxed">No YAML. No Python. Just <code class="text-white/60 bg-white/5 px-1 py-0.5 rounded text-[10px]">npx pwnkit-cli</code> and you're running.</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-6 hover:border-crimson/20 transition-colors">
            <div class="w-8 h-8 mb-4 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-2">Blind verification</h3>
            <p class="text-xs text-ash leading-relaxed">Every finding is independently re-exploited. Can't reproduce it? Killed as a false positive.</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-6 hover:border-crimson/20 transition-colors">
            <div class="w-8 h-8 mb-4 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-2">Bring your own AI</h3>
            <p class="text-xs text-ash leading-relaxed">Your API key, or use Claude Code CLI / Codex CLI with your subscription. Any model, any provider.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison -->
    <section id="comparison" data-section="comparison" class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 text-center" style="font-family: 'Outfit', sans-serif">How it compares</h2>

        <div class="bg-night-lighter border border-white/5 rounded-xl p-4 sm:p-6 overflow-x-auto">
          <p class="text-[10px] text-ash mb-2 sm:hidden">Scroll to compare &rarr;</p>
          <table class="w-full text-sm min-w-[600px]">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left py-3 pr-4 text-smoke font-medium">Feature</th>
                <th class="py-3 px-3 text-crimson font-bold"><img src="/pwnkit-icon.gif" class="w-4 h-4 inline-block mr-1" />pwnkit</th>
                <th class="py-3 px-3 text-ash font-medium">promptfoo <span class="text-[10px] text-ash/60 font-normal">(acquired by OpenAI)</span></th>
                <th class="py-3 px-3 text-ash font-medium">garak</th>
                <th class="py-3 px-3 text-ash font-medium">nuclei</th>
                <th class="py-3 px-3 text-ash font-medium">Semgrep</th>
              </tr>
            </thead>
            <tbody class="text-smoke">
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">Autonomous multi-agent</td>
                <td class="py-3 px-3 text-center text-emerald-400">Agentic pipeline</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">Verification (no false positives)</td>
                <td class="py-3 px-3 text-center text-emerald-400">Re-exploits</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">LLM endpoint scanning</td>
                <td class="py-3 px-3 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-3 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-3 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">npm package audit</td>
                <td class="py-3 px-3 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-emerald-400">Rules</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">Source code review</td>
                <td class="py-3 px-3 text-center text-emerald-400">AI-powered</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-emerald-400">Rules</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">AI attack coverage</td>
                <td class="py-3 px-3 text-center text-emerald-400">30+ agentic</td>
                <td class="py-3 px-3 text-center text-ash">Partial</td>
                <td class="py-3 px-3 text-center text-ash">Partial</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
                <td class="py-3 px-3 text-center text-ash">&mdash;</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">Zero config</td>
                <td class="py-3 px-3 text-center text-emerald-400">npx</td>
                <td class="py-3 px-3 text-center text-ash">YAML</td>
                <td class="py-3 px-3 text-center text-ash">Python</td>
                <td class="py-3 px-3 text-center text-ash">Templates</td>
                <td class="py-3 px-3 text-center text-ash">Config</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">Independent</td>
                <td class="py-3 px-3 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-3 text-center text-crimson">Acquired</td>
                <td class="py-3 px-3 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-3 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-3 text-center text-ash">VC-backed</td>
              </tr>
              <tr>
                <td class="py-3 pr-4">Open source</td>
                <td class="py-3 px-3 text-center text-emerald-400">Apache-2.0</td>
                <td class="py-3 px-3 text-center text-ash">OpenAI-owned</td>
                <td class="py-3 px-3 text-center text-emerald-400">OSS</td>
                <td class="py-3 px-3 text-center text-emerald-400">MIT</td>
                <td class="py-3 px-3 text-center text-ash">LGPL</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- CI/CD -->
    <section id="ci" data-section="ci" class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 text-center" style="font-family: 'Outfit', sans-serif">Findings in GitHub's Security tab.</h2>

        <div class="rounded-xl overflow-hidden border border-white/10">
          <div class="bg-night-lighter border-b border-white/5 px-4 py-2.5 flex items-center gap-2">
            <span class="text-xs text-ash font-mono">.github/workflows/pwnkit.yml</span>
          </div>
          <pre class="bg-night-light p-5 font-mono text-sm text-smoke overflow-x-auto leading-relaxed"><code><span class="text-ash">name:</span> <span class="text-amber-300">AI Security Scan</span>
<span class="text-ash">on:</span> <span class="text-white">[push, pull_request]</span>

<span class="text-ash">jobs:</span>
  <span class="text-white">pwnkit:</span>
    <span class="text-ash">runs-on:</span> <span class="text-emerald-400">ubuntu-latest</span>
    <span class="text-ash">steps:</span>
      - <span class="text-ash">uses:</span> <span class="text-blue-400">actions/checkout@v4</span>
      - <span class="text-ash">name:</span> <span class="text-amber-300">Run pwnkit</span>
        <span class="text-ash">uses:</span> <span class="text-blue-400">peaktwilight/pwnkit/action@v1</span>
        <span class="text-ash">with:</span>
          <span class="text-ash">target:</span> <span class="text-crimson">${"${{ secrets.STAGING_API_URL }}"}</span>
      - <span class="text-ash">name:</span> <span class="text-amber-300">Upload SARIF</span>
        <span class="text-ash">uses:</span> <span class="text-blue-400">github/codeql-action/upload-sarif@v3</span>
        <span class="text-ash">with:</span>
          <span class="text-ash">sarif_file:</span> <span class="text-emerald-400">pwnkit-report/report.sarif</span></code></pre>
        </div>
      </div>
    </section>

    <!-- Self-Scan Badge — live dogfooding results -->
    <section class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 text-center" style="font-family: 'Outfit', sans-serif">Dogfooding</h2>

        <div class="bg-night-lighter border border-white/5 rounded-xl p-6 sm:p-8">
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-5">
            <div class="flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
              <h3 class="font-semibold text-lg" style="font-family: 'Outfit', sans-serif">pwnkit reviews its own source code</h3>
            </div>
            <span class="text-xs text-ash">On every push via GitHub Actions</span>
          </div>
