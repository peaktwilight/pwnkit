---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nightfang - AI agents that hack your AI before attackers do">

  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-night/80 backdrop-blur-md border-b border-white/5">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight">
        <svg class="w-5 h-5 inline-block" viewBox="0 0 32 32"><rect width="32" height="32" rx="6" fill="#0a0a0a"/><path d="M8 12 L16 6 L24 12 L24 22 L20 26 L16 22 L12 26 L8 22Z" fill="none" stroke="#DC2626" stroke-width="2" stroke-linejoin="round"/><circle cx="13" cy="16" r="1.5" fill="#DC2626"/><circle cx="19" cy="16" r="1.5" fill="#DC2626"/></svg> nightfang
      </a>
      <div class="flex items-center gap-6 text-sm text-smoke">
        <a href="#how-it-works" class="hover:text-white transition-colors">How it works</a>
        <a href="#comparison" class="hover:text-white transition-colors hidden sm:block">Compare</a>
        <a href="https://github.com/peaktwilight/nightfang" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-md px-3 py-1.5 text-white transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <main>

    <!-- Hero -->
    <section class="relative min-h-screen flex items-center justify-center pt-14 overflow-hidden">
      <!-- Background grid -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(220,38,38,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(220,38,38,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
      <!-- Radial glow -->
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-crimson/5 rounded-full blur-[120px]"></div>

      <div class="relative max-w-4xl mx-auto px-6 text-center">
        <div class="animate-fade-up">
          <p class="inline-flex items-center gap-2 text-sm font-medium text-crimson mb-6 border border-crimson/20 rounded-full px-4 py-1.5 bg-crimson/5">
            <span class="w-1.5 h-1.5 rounded-full bg-crimson animate-pulse"></span>
            Open source &middot; MIT licensed
          </p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
            AI agents that hack your AI<br/>
            <span class="text-crimson">before attackers do</span>
          </h1>
          <p class="text-lg sm:text-xl text-smoke max-w-2xl mx-auto mb-10 leading-relaxed">
            Four autonomous agents probe your LLM apps, MCP servers, and AI pipelines for real vulnerabilities &mdash; then prove they're exploitable.
          </p>
        </div>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-up" style="animation-delay: 0.2s">
          <div class="group relative">
            <code class="block bg-night-lighter border border-white/10 rounded-lg px-6 py-3 font-mono text-sm sm:text-base text-white select-all cursor-pointer hover:border-crimson/30 transition-colors">
              npx nightfang scan --target https://your-app.com/api/chat
            </code>
          </div>
          <a href="https://github.com/peaktwilight/nightfang" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-crimson hover:bg-crimson-light text-white font-medium rounded-lg px-6 py-3 transition-colors text-sm sm:text-base">
            Get started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Terminal demo -->
        <div class="animate-fade-up max-w-2xl mx-auto" style="animation-delay: 0.4s">
          <div class="glow-crimson rounded-xl overflow-hidden border border-white/10">
            <!-- Terminal title bar -->
            <div class="bg-night-lighter border-b border-white/5 px-4 py-2.5 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
              </div>
              <span class="text-xs text-ash font-mono ml-2">Terminal</span>
            </div>
            <!-- Terminal content -->
            <div class="bg-night-light p-5 font-mono text-sm text-left leading-relaxed space-y-1">
              <div class="text-ash terminal-line">$ npx nightfang scan --target https://demo.app/api/chat</div>
              <div class="terminal-line">&nbsp;</div>
              <div class="text-smoke terminal-line">
                <svg class="w-5 h-5 inline-block" viewBox="0 0 32 32"><rect width="32" height="32" rx="6" fill="#0a0a0a"/><path d="M8 12 L16 6 L24 12 L24 22 L20 26 L16 22 L12 26 L8 22Z" fill="none" stroke="#DC2626" stroke-width="2" stroke-linejoin="round"/><circle cx="13" cy="16" r="1.5" fill="#DC2626"/><circle cx="19" cy="16" r="1.5" fill="#DC2626"/></svg> nightfang v0.1.0
              </div>
              <div class="text-smoke terminal-line">
                <span class="text-crimson">&#9646;</span> Target: https://demo.app/api/chat
              </div>
              <div class="terminal-line">&nbsp;</div>
              <div class="text-emerald-400 terminal-line">
                &#9656; Discover &nbsp;Found 3 endpoints, 2 MCP tools, system prompt extracted
              </div>
              <div class="text-amber-400 terminal-line">
                &#9656; Attack &nbsp;&nbsp;&nbsp;Ran 47 test cases across 6 categories
              </div>
              <div class="text-blue-400 terminal-line">
                &#9656; Verify &nbsp;&nbsp;&nbsp;Confirmed 4 of 7 findings (3 false positives eliminated)
              </div>
              <div class="text-purple-400 terminal-line">
                &#9656; Report &nbsp;&nbsp;&nbsp;Written to ./nightfang-report/
              </div>
              <div class="terminal-line">&nbsp;</div>
              <div class="terminal-line">
                <span class="text-crimson font-bold">4 verified vulnerabilities found.</span>
              </div>
              <div class="terminal-line">
                <table class="w-full text-xs sm:text-sm mt-2 border-collapse">
                  <thead>
                    <tr class="text-ash border-b border-white/10">
                      <th class="text-left py-1 pr-4">ID</th>
                      <th class="text-left py-1 pr-4">Finding</th>
                      <th class="text-left py-1 pr-4">Risk</th>
                      <th class="text-left py-1">Conf</th>
                    </tr>
                  </thead>
                  <tbody class="text-smoke">
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-001</td>
                      <td class="py-1 pr-4">Direct prompt injection</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">99%</td>
                    </tr>
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-002</td>
                      <td class="py-1 pr-4">System prompt extraction</td>
                      <td class="py-1 pr-4 text-amber-400 font-medium">MED</td>
                      <td class="py-1">95%</td>
                    </tr>
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-003</td>
                      <td class="py-1 pr-4">MCP tool SSRF via fetch_url</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">97%</td>
                    </tr>
                    <tr>
                      <td class="py-1 pr-4 text-white">NF-004</td>
                      <td class="py-1 pr-4">PII leak in chat context</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">92%</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- One command pitch -->
    <section class="py-24 border-t border-white/5">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8">
          <div class="space-y-3">
            <div class="w-10 h-10 rounded-lg bg-crimson/10 flex items-center justify-center text-crimson text-lg">&#9656;</div>
            <h3 class="text-lg font-semibold">One command, zero config</h3>
            <p class="text-smoke text-sm leading-relaxed">No YAML files. No Python environments. Just <code class="text-white bg-white/5 px-1.5 py-0.5 rounded text-xs">npx nightfang scan</code> and you're running.</p>
          </div>
          <div class="space-y-3">
            <div class="w-10 h-10 rounded-lg bg-crimson/10 flex items-center justify-center text-crimson text-lg">&#10003;</div>
            <h3 class="text-lg font-semibold">Zero false positives</h3>
            <p class="text-smoke text-sm leading-relaxed">Every finding is re-exploited with proof before it hits the report. No more triaging 200 "possible prompt injections."</p>
          </div>
          <div class="space-y-3">
            <div class="w-10 h-10 rounded-lg bg-crimson/10 flex items-center justify-center text-crimson text-lg">$</div>
            <h3 class="text-lg font-semibold">$0.05 per CI scan</h3>
            <p class="text-smoke text-sm leading-relaxed">Quick scans in under a minute. Deep audits for $1. Cheaper than one hour of manual pentesting.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works: 4-agent pipeline -->
    <section id="how-it-works" class="py-24 border-t border-white/5">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Four agents. One pipeline.</h2>
          <p class="text-smoke text-lg max-w-xl mx-auto">Each agent is specialized for a phase of the security audit. They work in sequence, building on each other's output.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Discover -->
          <div class="relative group">
            <div class="bg-night-lighter border border-white/5 rounded-xl p-6 hover:border-emerald-500/30 transition-colors h-full">
              <div class="text-xs font-mono text-emerald-400 mb-3 uppercase tracking-wider">01 &middot; Discover</div>
              <h3 class="font-semibold text-lg mb-2">Recon</h3>
              <p class="text-smoke text-sm leading-relaxed">Maps endpoints, model cards, system prompts, MCP tool schemas, and auth flows.</p>
              <div class="mt-4 pt-4 border-t border-white/5 text-xs text-ash font-mono space-y-1">
                <div>&#8226; API surface mapping</div>
                <div>&#8226; System prompt extraction</div>
                <div>&#8226; MCP tool enumeration</div>
              </div>
            </div>
            <div class="hidden lg:block absolute top-1/2 -right-3 text-white/20 text-lg">&#8594;</div>
          </div>

          <!-- Attack -->
          <div class="relative group">
            <div class="bg-night-lighter border border-white/5 rounded-xl p-6 hover:border-amber-500/30 transition-colors h-full">
              <div class="text-xs font-mono text-amber-400 mb-3 uppercase tracking-wider">02 &middot; Attack</div>
              <h3 class="font-semibold text-lg mb-2">Offense</h3>
              <p class="text-smoke text-sm leading-relaxed">Runs prompt injection, jailbreaks, tool poisoning, data exfiltration, and more.</p>
              <div class="mt-4 pt-4 border-t border-white/5 text-xs text-ash font-mono space-y-1">
                <div>&#8226; 47+ test cases</div>
                <div>&#8226; OWASP LLM Top 10</div>
                <div>&#8226; 6 attack categories</div>
              </div>
            </div>
            <div class="hidden lg:block absolute top-1/2 -right-3 text-white/20 text-lg">&#8594;</div>
          </div>

          <!-- Verify -->
          <div class="relative group">
            <div class="bg-night-lighter border border-white/5 rounded-xl p-6 hover:border-blue-500/30 transition-colors h-full">
              <div class="text-xs font-mono text-blue-400 mb-3 uppercase tracking-wider">03 &middot; Verify</div>
              <h3 class="font-semibold text-lg mb-2">Validation</h3>
              <p class="text-smoke text-sm leading-relaxed">Re-exploits each finding to eliminate false positives. Captures proof artifacts.</p>
              <div class="mt-4 pt-4 border-t border-white/5 text-xs text-ash font-mono space-y-1">
                <div>&#8226; Re-exploitation</div>
                <div>&#8226; Proof capture</div>
                <div>&#8226; Confidence scoring</div>
              </div>
            </div>
            <div class="hidden lg:block absolute top-1/2 -right-3 text-white/20 text-lg">&#8594;</div>
          </div>

          <!-- Report -->
          <div class="relative group">
            <div class="bg-night-lighter border border-white/5 rounded-xl p-6 hover:border-purple-500/30 transition-colors h-full">
              <div class="text-xs font-mono text-purple-400 mb-3 uppercase tracking-wider">04 &middot; Report</div>
              <h3 class="font-semibold text-lg mb-2">Output</h3>
              <p class="text-smoke text-sm leading-relaxed">Generates SARIF, Markdown, and JSON reports with severity and remediation.</p>
              <div class="mt-4 pt-4 border-t border-white/5 text-xs text-ash font-mono space-y-1">
                <div>&#8226; SARIF for GitHub Security tab</div>
                <div>&#8226; Markdown reports</div>
                <div>&#8226; Remediation guidance</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- OWASP Coverage -->
    <section class="py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">OWASP LLM Top 10 coverage</h2>
          <p class="text-smoke text-lg">8 out of 10 categories covered. The most comprehensive open-source coverage available.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {[
            { id: "LLM01", name: "Prompt Injection", covered: true, detail: "Direct + indirect" },
            { id: "LLM02", name: "Insecure Output Handling", covered: true, detail: "XSS, code exec" },
            { id: "LLM03", name: "Training Data Poisoning", covered: false, detail: "Detection only" },
            { id: "LLM04", name: "Model Denial of Service", covered: true, detail: "Resource exhaustion" },
            { id: "LLM05", name: "Supply Chain Vulns", covered: true, detail: "MCP tool poisoning" },
            { id: "LLM06", name: "Sensitive Info Disclosure", covered: true, detail: "PII/secret extraction" },
            { id: "LLM07", name: "Insecure Plugin Design", covered: true, detail: "Tool schema abuse, SSRF" },
            { id: "LLM08", name: "Excessive Agency", covered: true, detail: "Privilege escalation" },
            { id: "LLM09", name: "Overreliance", covered: false, detail: "Coming soon" },
            { id: "LLM10", name: "Model Theft", covered: true, detail: "Extraction, prompt theft" },
          ].map((item) => (
            <div class={`flex items-center gap-3 px-4 py-3 rounded-lg border ${item.covered ? 'border-white/5 bg-night-lighter' : 'border-white/5 bg-night-light opacity-50'}`}>
              <span class={`text-sm ${item.covered ? 'text-emerald-400' : 'text-ash'}`}>
                {item.covered ? '\u2713' : '\u2022'}
              </span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-xs font-mono text-ash">{item.id}</span>
                  <span class="text-sm font-medium text-white truncate">{item.name}</span>
                </div>
              </div>
              <span class="text-xs text-ash hidden sm:block">{item.detail}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Comparison -->
    <section id="comparison" class="py-24 border-t border-white/5">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">How it compares</h2>
          <p class="text-smoke text-lg">The only tool with autonomous multi-agent testing and verification.</p>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left py-3 pr-4 text-smoke font-medium">Feature</th>
                <th class="py-3 px-4 text-crimson font-bold">Nightfang</th>
                <th class="py-3 px-4 text-ash font-medium">promptfoo</th>
                <th class="py-3 px-4 text-ash font-medium">garak</th>
              </tr>
            </thead>
            <tbody class="text-smoke">
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">Autonomous multi-agent</td>
                <td class="py-3 px-4 text-center text-emerald-400">4 specialized agents</td>
                <td class="py-3 px-4 text-center text-ash">Single runner</td>
                <td class="py-3 px-4 text-center text-ash">Single runner</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">Verification (no false positives)</td>
                <td class="py-3 px-4 text-center text-emerald-400">Re-exploits to confirm</td>
                <td class="py-3 px-4 text-center text-ash">&mdash;</td>
                <td class="py-3 px-4 text-center text-ash">&mdash;</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">MCP server security</td>
                <td class="py-3 px-4 text-center text-emerald-400">Tool poisoning, schema abuse</td>
                <td class="py-3 px-4 text-center text-ash">&mdash;</td>
                <td class="py-3 px-4 text-center text-ash">&mdash;</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">OWASP LLM Top 10</td>
                <td class="py-3 px-4 text-center text-emerald-400">8/10 covered</td>
                <td class="py-3 px-4 text-center text-ash">Partial</td>
                <td class="py-3 px-4 text-center text-ash">Partial</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">SARIF output</td>
                <td class="py-3 px-4 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-4 text-center text-emerald-400">&check;</td>
                <td class="py-3 px-4 text-center text-ash">&mdash;</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-3 pr-4">Zero config</td>
                <td class="py-3 px-4 text-center text-emerald-400">npx nightfang scan</td>
                <td class="py-3 px-4 text-center text-ash">YAML config required</td>
                <td class="py-3 px-4 text-center text-ash">Python setup</td>
              </tr>
              <tr>
                <td class="py-3 pr-4">Open source</td>
                <td class="py-3 px-4 text-center text-emerald-400">MIT</td>
                <td class="py-3 px-4 text-center text-ash">Acquired by OpenAI</td>
                <td class="py-3 px-4 text-center text-emerald-400">Open source</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- CI/CD -->
    <section class="py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Drops into your CI/CD</h2>
          <p class="text-smoke text-lg">Findings show up directly in GitHub's Security tab.</p>
        </div>

        <div class="glow-crimson rounded-xl overflow-hidden border border-white/10">
          <div class="bg-night-lighter border-b border-white/5 px-4 py-2.5 flex items-center gap-2">
            <span class="text-xs text-ash font-mono">.github/workflows/nightfang.yml</span>
          </div>
          <pre class="bg-night-light p-5 font-mono text-sm text-smoke overflow-x-auto leading-relaxed"><code><span class="text-ash">name:</span> <span class="text-amber-300">AI Security Scan</span>
<span class="text-ash">on:</span> <span class="text-white">[push, pull_request]</span>

<span class="text-ash">jobs:</span>
  <span class="text-white">nightfang:</span>
    <span class="text-ash">runs-on:</span> <span class="text-emerald-400">ubuntu-latest</span>
    <span class="text-ash">steps:</span>
      - <span class="text-ash">uses:</span> <span class="text-blue-400">actions/checkout@v4</span>
      - <span class="text-ash">name:</span> <span class="text-amber-300">Run Nightfang</span>
        <span class="text-ash">uses:</span> <span class="text-blue-400">peaktwilight/nightfang-action@v1</span>
        <span class="text-ash">with:</span>
          <span class="text-ash">target:</span> <span class="text-crimson">${"${{ secrets.STAGING_API_URL }}"}</span>
      - <span class="text-ash">name:</span> <span class="text-amber-300">Upload SARIF</span>
        <span class="text-ash">uses:</span> <span class="text-blue-400">github/codeql-action/upload-sarif@v3</span>
        <span class="text-ash">with:</span>
          <span class="text-ash">sarif_file:</span> <span class="text-emerald-400">nightfang-report/report.sarif</span></code></pre>
        </div>
      </div>
    </section>

    <!-- Cost section -->
    <section class="py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Costs less than coffee</h2>
        </div>

        <div class="grid sm:grid-cols-3 gap-6">
          <div class="bg-night-lighter border border-white/5 rounded-xl p-6 text-center">
            <div class="text-xs font-mono text-ash uppercase tracking-wider mb-3">Quick</div>
            <div class="text-3xl font-bold text-white mb-1">$0.05</div>
            <div class="text-sm text-smoke mb-4">~15 tests &middot; 1 min</div>
            <div class="text-xs text-ash">Perfect for CI</div>
          </div>
          <div class="bg-night-lighter border border-crimson/20 rounded-xl p-6 text-center relative">
