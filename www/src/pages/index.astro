---
import Layout from '../layouts/Layout.astro';
import PipelineViz from '../components/PipelineViz';
import DockNav from '../components/DockNav';
import DataGridBackground from '../components/DataGridBackground';
---

<Layout title="pwnkit - Open-source agentic framework for autonomous security research">


  <main>

    <!-- Hero -->
    <section data-section="hero" class="relative min-h-screen pt-32 pb-16 overflow-hidden">
      <!-- Data grid animated background -->
      <DataGridBackground client:load />

      <div class="relative max-w-6xl mx-auto px-6 text-center">
        <div class="animate-fade-up">
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-6" style="font-family: 'Outfit', sans-serif">
            AI writes the code.<br/><span class="text-crimson">pwnkit hacks it.</span>
          </h1>
          <p class="text-lg sm:text-xl text-smoke max-w-2xl mx-auto mb-4 leading-relaxed">
            Open-source agentic framework for autonomous security research.
          </p>
          <p class="text-sm text-white/50 max-w-lg mx-auto mb-3">
            Not just detection &mdash; exploit-backed proof of every finding.
          </p>
          <p class="text-xs text-ash max-w-md mx-auto mb-10">
            Built from <a href="https://doruk.ch/blog" class="text-white/60 underline underline-offset-2 decoration-white/20 hover:decoration-white/50 transition-colors">7 real CVEs</a> in packages with 40M+ downloads &middot; General-purpose autonomous pentesting
          </p>
        </div>

        <!-- CTA -->
        <div class="flex flex-col items-center gap-4 mb-16 animate-fade-up" style="animation-delay: 0.2s">
          <div class="copy-wrap relative inline-flex items-center group">
            <code class="bg-night-lighter border border-white/10 rounded-lg px-5 py-3 pr-11 text-sm font-mono text-white select-all cursor-pointer hover:border-crimson/30 transition-colors" data-copy="npx pwnkit-cli audit your-package">npx pwnkit-cli audit <span class="text-crimson/70">your-package</span></code>
            <button class="copy-btn absolute right-2 p-1.5 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli audit your-package">
              <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
            </button>
          </div>
          <a href="https://github.com/peaktwilight/pwnkit" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white hover:bg-white/90 text-black font-medium rounded-lg px-6 py-3 transition-colors text-sm">
            View on GitHub
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Demo GIF — real CLI output, not a simulation -->
        <div class="animate-fade-up max-w-5xl mx-auto" style="animation-delay: 0.4s">
          <div class="glow-crimson rounded-xl overflow-hidden border border-white/10 shadow-[0_0_60px_-12px_rgba(220,38,38,0.3)]">
            <img src="/demo.gif" alt="pwnkit scanning a target and finding vulnerabilities" class="w-full" loading="eager" style="max-width: 100%" />
          </div>
          <!-- Static fallback for no-JS -->
          <noscript>
          <div class="glow-crimson rounded-xl overflow-hidden border border-white/10">
            <div class="bg-night-lighter border-b border-white/5 px-4 py-2.5 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
              </div>
              <span class="text-xs text-ash font-mono ml-2">Terminal</span>
            </div>
            <div class="bg-night-light p-5 font-mono text-sm text-left leading-relaxed space-y-1">
              <div class="text-ash terminal-line">$ npx pwnkit-cli scan --target https://demo.app/api/chat</div>
              <div class="terminal-line">&nbsp;</div>
              <div class="text-smoke terminal-line">
                <svg class="w-5 h-5 inline-block" viewBox="0 0 32 32"><rect width="32" height="32" rx="6" fill="#0a0a0a"/><path d="M8 12 L16 6 L24 12 L24 22 L20 26 L16 22 L12 26 L8 22Z" fill="none" stroke="#DC2626" stroke-width="2" stroke-linejoin="round"/><circle cx="13" cy="16" r="1.5" fill="#DC2626"/><circle cx="19" cy="16" r="1.5" fill="#DC2626"/></svg> pwnkit v0.1.0
              </div>
              <div class="text-smoke terminal-line">
                <span class="inline-block w-2 h-2 rounded-sm bg-crimson"></span> Target: https://demo.app/api/chat
              </div>
              <div class="terminal-line">&nbsp;</div>
              <div class="text-emerald-400 terminal-line">
                &#9656; Discover &nbsp;Found 3 endpoints, 2 MCP tools, system prompt extracted
              </div>
              <div class="text-amber-400 terminal-line">
                &#9656; Attack &nbsp;&nbsp;&nbsp;Ran 47 test cases across 6 categories
              </div>
              <div class="text-blue-400 terminal-line">
                &#9656; Verify &nbsp;&nbsp;&nbsp;Confirmed 4 of 7 findings (3 false positives eliminated)
              </div>
              <div class="text-purple-400 terminal-line">
                &#9656; Report &nbsp;&nbsp;&nbsp;Written to ./pwnkit-report/
              </div>
              <div class="terminal-line">&nbsp;</div>
              <div class="terminal-line">
                <span class="text-crimson font-bold">4 verified vulnerabilities found.</span>
              </div>
              <div class="terminal-line">
                <table class="w-full text-xs sm:text-sm mt-2 border-collapse">
                  <thead>
                    <tr class="text-ash border-b border-white/10">
                      <th class="text-left py-1 pr-4">ID</th>
                      <th class="text-left py-1 pr-4">Finding</th>
                      <th class="text-left py-1 pr-4">Risk</th>
                      <th class="text-left py-1">Conf</th>
                    </tr>
                  </thead>
                  <tbody class="text-smoke">
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-001</td>
                      <td class="py-1 pr-4">Direct prompt injection</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">99%</td>
                    </tr>
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-002</td>
                      <td class="py-1 pr-4">System prompt extraction</td>
                      <td class="py-1 pr-4 text-amber-400 font-medium">MED</td>
                      <td class="py-1">95%</td>
                    </tr>
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-003</td>
                      <td class="py-1 pr-4">MCP tool SSRF via fetch_url</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">97%</td>
                    </tr>
                    <tr>
                      <td class="py-1 pr-4 text-white">NF-004</td>
                      <td class="py-1 pr-4">PII leak in chat context</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">92%</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          </noscript>
        </div>
      </div>
    </section>

    <!-- What you can scan -->
    <section class="py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4" style="font-family: 'Outfit', sans-serif">General-purpose autonomous pentesting.</h2>
          <p class="text-smoke text-lg max-w-xl mx-auto">Web apps, APIs, npm packages, source code, AI endpoints &mdash; pwnkit finds what scanners miss.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">LLM Endpoints</h3>
            <p class="text-xs text-ash">ChatGPT, Claude, Llama APIs, custom chatbots</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6m0 8v6M4.93 4.93l4.24 4.24m5.66 5.66l4.24 4.24M2 12h6m8 0h6M4.93 19.07l4.24-4.24m5.66-5.66l4.24-4.24"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">MCP Servers</h3>
            <p class="text-xs text-ash">Tool schemas, validation, auth, poisoning</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">npm Packages</h3>
            <p class="text-xs text-ash">Supply chain, malicious code, dependency risk</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">Source Code</h3>
            <p class="text-xs text-ash">Local repos, GitHub URLs, deep AI audit</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">Web Apps</h3>
            <p class="text-xs text-ash">SQLi, XSS, SSRF, auth bypass, IDOR, full pentest</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 5 Commands -->
    <section id="commands" data-section="commands" class="py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-6">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4" style="font-family: 'Outfit', sans-serif">Just give it a target.</h2>
          <p class="text-smoke text-lg max-w-xl mx-auto">pwnkit auto-detects what you're scanning. Or use explicit commands for full control.</p>
        </div>

        <!-- Auto-detect examples -->
        <div class="bg-night-lighter border border-white/5 rounded-xl p-5 mb-8">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs font-mono">
            <div><span class="text-ash">npm package</span><br/><code class="text-white">pwnkit express</code></div>
            <div><span class="text-ash">your repo</span><br/><code class="text-white">pwnkit ./my-app</code></div>
            <div><span class="text-ash">website</span><br/><code class="text-white">pwnkit https://example.com --mode web</code></div>
          </div>
        </div>

        <div class="space-y-4">
          <!-- scan -->
          <div class="bg-night-lighter border border-white/5 rounded-xl overflow-hidden hover:border-crimson/20 transition-colors">
            <div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-mono text-crimson bg-crimson/10 px-2 py-0.5 rounded uppercase tracking-wider">scan</span>
                  <h3 class="font-semibold text-lg">Scan endpoints, APIs, and web apps</h3>
                </div>
                <p class="text-smoke text-sm leading-relaxed mb-3">AI endpoints, MCP servers, REST APIs, or full web apps. Autonomous agents probe, attack, and verify. Web mode does SQLi, XSS, SSRF, auth bypass, IDOR.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">--mode probe|deep|mcp|web</span>
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">--depth quick|default|deep</span>
                </div>
              </div>
              <div class="lg:w-[340px] shrink-0">
                <div class="copy-wrap relative flex items-center">
                  <code class="block w-full bg-night border border-white/5 rounded-lg px-4 py-3 pr-10 font-mono text-xs text-smoke select-all overflow-x-auto" data-copy="npx pwnkit-cli scan --target <url>">npx pwnkit-cli scan --target &lt;url&gt;</code>
                  <button class="copy-btn absolute right-2 p-1 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli scan --target <url>">
                    <svg class="w-3.5 h-3.5 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                    <svg class="w-3.5 h-3.5 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- audit -->
          <div class="bg-night-lighter border border-white/5 rounded-xl overflow-hidden hover:border-crimson/20 transition-colors">
            <div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-mono text-amber-400 bg-amber-400/10 px-2 py-0.5 rounded uppercase tracking-wider">audit</span>
                  <h3 class="font-semibold text-lg">Audit npm packages for malicious code</h3>
                </div>
                <p class="text-smoke text-sm leading-relaxed mb-3">Installs a package in a sandbox, runs semgrep static analysis plus AI-powered code review. Catches supply chain attacks, backdoors, and dependency vulnerabilities.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">--version &lt;ver&gt;</span>
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">--depth quick|default|deep</span>
                </div>
              </div>
              <div class="lg:w-[340px] shrink-0">
                <div class="copy-wrap relative flex items-center">
                  <code class="block w-full bg-night border border-white/5 rounded-lg px-4 py-3 pr-10 font-mono text-xs text-smoke select-all overflow-x-auto" data-copy="npx pwnkit-cli audit <package>">npx pwnkit-cli audit &lt;package&gt;</code>
                  <button class="copy-btn absolute right-2 p-1 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli audit <package>">
                    <svg class="w-3.5 h-3.5 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                    <svg class="w-3.5 h-3.5 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- review -->
          <div class="bg-night-lighter border border-white/5 rounded-xl overflow-hidden hover:border-crimson/20 transition-colors">
            <div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-mono text-blue-400 bg-blue-400/10 px-2 py-0.5 rounded uppercase tracking-wider">review</span>
                  <h3 class="font-semibold text-lg">Deep security audit of source code</h3>
                </div>
                <p class="text-smoke text-sm leading-relaxed mb-3">Security-focused code review of local repos or GitHub URLs. Multiple AI runtimes analyze your entire codebase and output SARIF, Markdown, and JSON reports.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">--runtime api|claude|codex|gemini|auto</span>
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">--depth quick|default|deep</span>
                </div>
              </div>
              <div class="lg:w-[340px] shrink-0">
                <div class="copy-wrap relative flex items-center">
                  <code class="block w-full bg-night border border-white/5 rounded-lg px-4 py-3 pr-10 font-mono text-xs text-smoke select-all overflow-x-auto" data-copy="npx pwnkit-cli review <repo>">npx pwnkit-cli review &lt;repo&gt;</code>
                  <button class="copy-btn absolute right-2 p-1 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli review <repo>">
                    <svg class="w-3.5 h-3.5 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                    <svg class="w-3.5 h-3.5 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- findings -->
          <div class="bg-night-lighter border border-white/5 rounded-xl overflow-hidden hover:border-crimson/20 transition-colors">
            <div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-mono text-purple-400 bg-purple-400/10 px-2 py-0.5 rounded uppercase tracking-wider">findings</span>
                  <h3 class="font-semibold text-lg">Query and inspect verified findings</h3>
                </div>
                <p class="text-smoke text-sm leading-relaxed mb-3">Filter findings by severity, category, and status. Inspect individual findings with full evidence chains and proof artifacts. Track the lifecycle from discovered to confirmed.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">list --severity critical</span>
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">show NF-001</span>
                </div>
              </div>
              <div class="lg:w-[340px] shrink-0">
                <div class="copy-wrap relative flex items-center">
                  <code class="block w-full bg-night border border-white/5 rounded-lg px-4 py-3 pr-10 font-mono text-xs text-smoke select-all overflow-x-auto" data-copy="npx pwnkit-cli findings list">npx pwnkit-cli findings list</code>
                  <button class="copy-btn absolute right-2 p-1 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli findings list">
                    <svg class="w-3.5 h-3.5 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                    <svg class="w-3.5 h-3.5 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- history -->
          <div class="bg-night-lighter border border-white/5 rounded-xl overflow-hidden hover:border-crimson/20 transition-colors">
            <div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-mono text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded uppercase tracking-wider">history</span>
                  <h3 class="font-semibold text-lg">Browse past scan results</h3>
                </div>
                <p class="text-smoke text-sm leading-relaxed mb-3">Query the local SQLite database for previous scans. See status, depth, findings count, and duration for every run. Track your security posture over time.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">--limit 20</span>
                  <span class="text-xs font-mono text-ash bg-white/5 px-2 py-0.5 rounded">--db-path ./custom.db</span>
                </div>
              </div>
              <div class="lg:w-[340px] shrink-0">
                <div class="copy-wrap relative flex items-center">
                  <code class="block w-full bg-night border border-white/5 rounded-lg px-4 py-3 pr-10 font-mono text-xs text-smoke select-all overflow-x-auto" data-copy="npx pwnkit-cli history">npx pwnkit-cli history</code>
                  <button class="copy-btn absolute right-2 p-1 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli history">
                    <svg class="w-3.5 h-3.5 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                    <svg class="w-3.5 h-3.5 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
